pipeline {
    agent any
    tools { 
        maven 'maven-local' 
    }
    stages {
        stage('Clone Code') {
            steps {
                git url: 'https://github.com/diegorojasdvlp/wazuh-export-agent', branch: 'LocalTest'
            }
        }
        stage('Build for Test') {
            steps {
                sh 'mvn clean package -DskipTests' // Adjust goals if needed (e.g., install, deploy)
            }
        }
        stage('SonarQube Analysis') {
            steps {
                script {
                    scannerHome = tool 'sonar-scanner'// must match the name of an actual scanner installation directory on your Jenkins build agent
                }
                withSonarQubeEnv('sonar-local') {
                    sh "${scannerHome}/bin/sonar-scanner -Dsonar.projectKey=test -Dsonar.projectName=test -Dsonar.sources=src/ -Dsonar.java.binaries=target/classes -Dsonar.java.libraries=/var/jenkins_home/.m2/**/*.jar"
                }
            }
        }
        stage('Quality Gate') {
            steps {
                timeout(time: 2, unit: 'MINUTES') {
                    script {
                        def quality_gate = waitForQualityGate()
                        if (quality_gate.status != 'OK') {
                            error "Pipeline aborted due to quality gate failure: ${qg.status}"
                        } else {
                            echo "Pipeline OK"
                        }
                    }
                }
            }
        }
        stage('Deploy for Test') {
            steps {
                sh 'nohup java -jar target/wazuh-export-agent-0.0.1-SNAPSHOT.jar > /var/jenkins_home/logs/pentest.log 2>&1 &'
                sh 'sleep 10s'
            }
        }
        stage('OWASP ZAP Check') {
            steps {
                timeout(time: 3, unit: 'MINUTES') {
                    script {
                        def response = sh(script: "curl -s \"http://owasp-zap:8091/JSON/spider/action/scan/?apikey=01f9fa39f63adc6b3bbb70d33c6ffbac592bf57d90a87024a9a20c7ff6aa9045&url=http://jenkins:8081/api/vulnerability/critical&maxChildren=&recurse=&contextName=&subtreeOnly=\"", returnStdout: true).trim()
                        echo "Response: ${response}"
                    }
                }
            }
        }
        stage('Docker Build') {
            steps {
                script {
                    def imageName = "wazuh-export-agent"
                    def imageTag  = "${imageName}:${env.BUILD_NUMBER}"
                    env.DOCKER_IMAGE = imageTag
                    echo "Building Docker image: ${imageTag}"
                    sh "docker build -t ${imageTag} -t ${imageName}:latest ."
                    echo "Docker image built successfully: ${imageTag}"
                }
            }
        }
        stage('Docker Deploy') {
            steps {
                script {
                    echo "Stopping and removing existing application container (if any)..."
                    sh '''
                        docker stop wazuh-export-agent || true
                        docker rm   wazuh-export-agent || true
                    '''
                    echo "Starting application container from image: ${env.DOCKER_IMAGE}"
                    sh """
                        docker run -d \\
                            --name wazuh-export-agent \\
                            --network cicd \\
                            -p 8081:8081 \\
                            ${env.DOCKER_IMAGE}
                    """
                    echo "Application deployed successfully. Container: wazuh-export-agent"
                }
            }
        }
    }
}